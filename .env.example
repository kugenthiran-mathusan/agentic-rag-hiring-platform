# ===== MongoDB =====
MONGO_URI=mongodb://admin:admin@localhost:27017/hiring?authSource=admin
MONGO_DB=hiring

# ===== Qdrant =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=resumes

# ===== Files =====
UPLOAD_DIR=./storage

# ===== LLM Provider =====
LLM_PROVIDER=gemini
GEMINI_API_KEY=put_your_key_here
GEMINI_MODEL=gemini-3-flash-preview

# ===== App =====
APP_ENV=dev
